{
  "realm": "movies",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": false,
  "bruteForceProtected": false,
  "roles": {
    "realm": [
      {
        "name": "MOVIES_USER",
        "description": "Read movies, create movies, and add comments"
      },
      {
        "name": "MOVIES_ADMIN",
        "description": "Administer movies and users"
      }
    ]
  },
  "clientScopes": [
    {
      "name": "movies-api-audience",
      "description": "Adds movies-api to token audiences",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "false",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "aud-movies-api",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "movies-api",
            "access.token.claim": "true",
            "id.token.claim": "false",
            "introspection.token.claim": "true"
          }
        }
      ]
    }
  ],
  "clients": [
    {
      "clientId": "movies-ui",
      "name": "Movies UI",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "bearerOnly": false,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:7000/*",
        "http://localhost:8079/*"
      ],
      "webOrigins": [
        "http://localhost:7000",
        "http://localhost:8079"
      ],
      "protocol": "openid-connect",
      "fullScopeAllowed": true,
      "defaultClientScopes": [
        "profile",
        "email",
        "roles",
        "movies-api-audience"
      ],
      "protocolMappers": [
        {
          "name": "aud-movie-gateway",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "movie-gateway",
            "access.token.claim": "true",
            "id.token.claim": "false",
            "introspection.token.claim": "true"
          }
        },
        {
          "name": "aud-movies-api",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "movies-api",
            "access.token.claim": "true",
            "id.token.claim": "false",
            "introspection.token.claim": "true"
          }
        },
        {
          "name": "realm-roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "claim.name": "realm_access.roles",
            "jsonType.label": "String",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true",
            "introspection.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "movie-gateway",
      "name": "Movie Gateway",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "gateway-secret",
      "bearerOnly": false,
      "publicClient": false,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": true,
      "redirectUris": [
        "http://localhost:8079/*"
      ],
      "webOrigins": [
        "http://localhost:8079"
      ],
      "protocol": "openid-connect",
      "fullScopeAllowed": true,
      "attributes": {
        "standard.token.exchange.enabled": "true"
      },
      "defaultClientScopes": [
        "profile",
        "email",
        "roles",
        "movies-api-audience"
      ],
      "protocolMappers": [
        {
          "name": "aud-movies-api",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "movies-api",
            "access.token.claim": "true",
            "id.token.claim": "false",
            "introspection.token.claim": "true"
          }
        },
        {
          "name": "realm-roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "claim.name": "realm_access.roles",
            "jsonType.label": "String",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true",
            "introspection.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "movies-api",
      "name": "Movies API Audience",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "bearerOnly": true,
      "publicClient": false,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "protocol": "openid-connect",
      "fullScopeAllowed": true
    }
  ],
  "groups": [
    {
      "name": "USERS",
      "path": "/USERS",
      "realmRoles": [
        "MOVIES_USER"
      ]
    },
    {
      "name": "ADMINS",
      "path": "/ADMINS",
      "realmRoles": [
        "MOVIES_USER",
        "MOVIES_ADMIN"
      ]
    }
  ],
  "defaultGroups": [
    "/USERS"
  ],
  "users": [
    {
      "username": "user",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Regular",
      "lastName": "User",
      "email": "user@example.com",
      "groups": [
        "/USERS"
      ],
      "realmRoles": [
        "MOVIES_USER"
      ],
      "credentials": [
        {
          "type": "password",
          "value": "user",
          "temporary": false
        }
      ]
    },
    {
      "username": "admin",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Admin",
      "lastName": "User",
      "email": "admin@example.com",
      "groups": [
        "/ADMINS"
      ],
      "realmRoles": [
        "MOVIES_USER",
        "MOVIES_ADMIN"
      ],
      "credentials": [
        {
          "type": "password",
          "value": "admin",
          "temporary": false
        }
      ]
    }
  ]
}
