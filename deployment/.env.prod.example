# AWS and infrastructure
AWS_REGION=eu-central-1
INFRA_NAME_PREFIX=movie-stream
CLUSTER_VERSION=1.32
NODE_INSTANCE_TYPE=m6i.large
NODE_MIN_SIZE=2
NODE_DESIRED_SIZE=2
NODE_MAX_SIZE=4
SINGLE_NAT_GATEWAY=true
STATEFUL_AVAILABILITY_ZONE=eu-central-1a
STATEFUL_NODE_INSTANCE_TYPE=m6i.large
STATEFUL_NODE_MIN_SIZE=1
STATEFUL_NODE_DESIRED_SIZE=1
STATEFUL_NODE_MAX_SIZE=2

# Container registry. For GitHub Container Registry use ghcr.io/<user-or-org>.
DOCKER_SERVER=ghcr.io
CONTAINER_REGISTRY=ghcr.io/your-github-user-or-org
GITHUB_USERNAME=your-github-username
GITHUB_TOKEN=ghp_replace_with_package_write_token
IMAGE_VERSION=1.2.0-movie-challenge
# Optional cross-platform build, for example linux/amd64 when building on Apple Silicon.
# DOCKER_PLATFORM=linux/amd64

# Public application endpoint and TLS certificate.
APP_NAMESPACE=movie-stream
APP_DOMAIN=movies.example.com
APP_BASE_URL=https://movies.example.com
KEYCLOAK_DOMAIN=keycloak.movies.example.com
KEYCLOAK_EXTERNAL_URL=https://keycloak.movies.example.com
AWS_ACM_CERTIFICATE_ARN=arn:aws:acm:eu-central-1:123456789012:certificate/replace-me

# Existing EBS gp3 volumes for Postgres persistence. Create them manually in
# STATEFUL_AVAILABILITY_ZONE so Terraform-managed nodes can mount them.
MOVIES_POSTGRES_VOLUME_ID=vol-0123456789abcdef0
MOVIES_POSTGRES_VOLUME_AZ=eu-central-1a
MOVIES_POSTGRES_STORAGE_SIZE=70Gi
KEYCLOAK_POSTGRES_VOLUME_ID=vol-0123456789abcdef1
KEYCLOAK_POSTGRES_VOLUME_AZ=eu-central-1a
KEYCLOAK_POSTGRES_STORAGE_SIZE=10Gi

# Movie database
MOVIES_JDBC_URL=jdbc:postgresql://movies-postgres:5432/movies
MOVIES_JDBC_USERNAME=movies
MOVIES_JDBC_PASSWORD=change-me-movies-db-password

# Keycloak database and admin
KEYCLOAK_POSTGRES_DB=keycloak
KEYCLOAK_POSTGRES_USER=keycloak
KEYCLOAK_POSTGRES_PASSWORD=change-me-keycloak-db-password
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-keycloak-admin-password

# pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@movies.example.com
PGADMIN_DEFAULT_PASSWORD=change-me-pgadmin-password

# UI/runtime config
OMDB_API_KEY=replace-with-omdb-key
JAVA_OPTS=-XX:MaxRAMPercentage=75
