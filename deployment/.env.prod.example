# AWS and infrastructure
AWS_REGION=eu-central-1
INFRA_NAME_PREFIX=movie-stream
AVAILABILITY_ZONE=eu-central-1a
VPC_CIDR=10.52.0.0/16
PUBLIC_SUBNET_CIDR=10.52.0.0/24

# EC2 instance running Docker Compose
EC2_INSTANCE_TYPE=t3.large
EC2_AMI_ARCHITECTURE=x86_64
EC2_ROOT_VOLUME_SIZE=30
SSH_PUBLIC_KEY_PATH=.ssh/movie-stream.pub
SSH_PRIVATE_KEY_PATH=.ssh/movie-stream
SSH_ALLOWED_CIDR=203.0.113.10/32
EC2_SSH_USER=ec2-user
REMOTE_APP_DIR=/opt/movie-stream

# Optional Route 53 automation. Leave disabled if you prefer to create the A record manually.
MANAGE_ROUTE53_RECORD=false
ROUTE53_HOSTED_ZONE_ID=

# Container registry. For GitHub Container Registry use ghcr.io/<user-or-org>.
DOCKER_SERVER=ghcr.io
CONTAINER_REGISTRY=ghcr.io/your-github-user-or-org
GITHUB_USERNAME=your-github-username
GITHUB_TOKEN=ghp_replace_with_package_write_token
IMAGE_VERSION=1.2.0-movie-challenge

# Public application endpoint. Caddy uses Let's Encrypt automatically for APP_DOMAIN.
APP_DOMAIN=example.com
APP_BASE_URL=https://example.com
KEYCLOAK_EXTERNAL_URL=https://example.com/keycloak

# Existing EBS gp3 volumes for Postgres persistence. Create them manually in AVAILABILITY_ZONE.
MOVIES_POSTGRES_VOLUME_ID=vol-0123456789abcdef0
MOVIES_POSTGRES_DEVICE_NAME=/dev/sdf
MOVIES_POSTGRES_HOST_DIR=/mnt/movie-stream/movies-postgres
KEYCLOAK_POSTGRES_VOLUME_ID=vol-0123456789abcdef1
KEYCLOAK_POSTGRES_DEVICE_NAME=/dev/sdg
KEYCLOAK_POSTGRES_HOST_DIR=/mnt/movie-stream/keycloak-postgres

# Movie database
MOVIES_JDBC_URL=jdbc:postgresql://postgres-movies:5432/movies
MOVIES_JDBC_USERNAME=movies
MOVIES_JDBC_PASSWORD=change-me-movies-db-password

# Keycloak database and admin
KEYCLOAK_REALM=movies
KEYCLOAK_POSTGRES_DB=keycloak
KEYCLOAK_POSTGRES_USER=keycloak
KEYCLOAK_POSTGRES_PASSWORD=change-me-keycloak-db-password
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-keycloak-admin-password

# pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=change-me-pgadmin-password
PGADMIN_HOST_DIR=/mnt/movie-stream/pgadmin

# UI/runtime config
OMDB_API_KEY=replace-with-omdb-key
MOVIES_PER_PAGE=50
JAVA_OPTS=-XX:MaxRAMPercentage=75
